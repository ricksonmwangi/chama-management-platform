# URL of your running Express backend. Routes are mounted at root
# (e.g. http://localhost:3000/members, not /api/members).
VITE_API_URL=http://localhost:3000

# Google reCAPTCHA v2 site key (public — safe to expose in frontend code).
# Get one at https://www.google.com/recaptcha/admin — register a
# "reCAPTCHA v2 / I'm not a robot Checkbox" site, add localhost as an
# allowed domain for local dev. Pair with RECAPTCHA_SECRET_KEY in the
# backend's .env — they're two different keys from the same registration.
VITE_RECAPTCHA_SITE_KEY=
